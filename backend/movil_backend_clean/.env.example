# Base de datos PostgreSQL (la misma que usa el backend web)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=distriexpress
DB_USER=postgres
DB_PASSWORD=root
DB_SCHEMA=distriexpress

# JWT - usar el MISMO secreto que el backend web para que los tokens sean compatibles
JWT_SECRET=tu_jwt_secret_super_seguro
JWT_EXPIRES_IN=7d

# Puerto del servidor móvil (diferente al web para no colisionar)
PORT=5001

NODE_ENV=development
